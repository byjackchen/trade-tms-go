    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@types/node": "20.19.39",
    "@types/pg": "8.11.10",
    "pg": "8.13.1",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
