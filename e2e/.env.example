# e2e suite configuration. Copy to e2e/.env (or export in the shell) to override
# the host-reserved defaults baked into lib/env.ts. Nothing here is required for
# a standard local run against the compose stack.

# UI + API host base URLs (compose-mapped host ports).
TMS_E2E_UI_URL=http://localhost:13000
TMS_E2E_API_URL=http://localhost:18080

# MANUAL trading desk (P6) host base URL — serving POST /api/v1/trade/*. The desk
# lives in the broker-connected live node (:18091); the compose `app` API
# REVERSE-PROXIES /api/v1/trade/* onto it (TMS_MANUAL_TRADE_URL), so this defaults
# to the API host and the suite hits one host. The desk's specs (32-38) self-skip
# when GET /api/v1/trade/status returns 503 (no desk connected). Bring the desk up
# with the `manual` compose profile (mock OpenD + a paper manual live node):
#   docker compose --profile app --profile manual up -d --wait
TMS_E2E_MANUAL_URL=http://localhost:18080
# The paper trade-password the desk demands in confirm_token for a PAPER manual
# order, and the symbol the manual specs trade on the mock venue.
TMS_E2E_PAPER_TRADE_PASSWORD=paper-trade-password
TMS_E2E_MANUAL_SYMBOL=AAPL

# Bearer token — MUST equal the API's TMS_API_TOKEN and the UI proxy's token.
# The gate writes this into the root .env; mirror it here for direct API tests.
TMS_API_TOKEN=local-e2e-token

# Direct postgres (host-mapped) for DB-truth assertions + seeding.
TMS_PG_HOST=127.0.0.1
TMS_PG_PORT=55432
TMS_PG_USER=tms
TMS_PG_PASSWORD=tms
TMS_PG_DATABASE=tms

# How long (ms) global-setup waits for the stack to become app-ready.
TMS_E2E_STACK_TIMEOUT_MS=120000
