# Copy to .env.local for local `npm run dev`. Never commit real secrets.
#
# The UI server proxies the TMS API; the bearer token lives ONLY here (server
# side) and is never shipped to the browser.

# Bearer token for the TMS API — must equal the API's TMS_API_TOKEN. Required;
# the UI proxy returns 500 ("ui server is not configured") without it.
TMS_API_TOKEN=

# Internal HTTP base the UI server dials to reach the API.
#   local dev (host-mapped):   http://127.0.0.1:18080
#   docker compose (in-network): http://tmsgo-api:8080
TMS_API_URL=http://127.0.0.1:18080

# Optional explicit WS base; derived from TMS_API_URL (http->ws) when unset.
# TMS_API_WS_URL=ws://127.0.0.1:18080
