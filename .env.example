# 复制本文件为 .env 并填入真实值。.env 已被 gitignore，绝不提交。
# 加载语义与 Python 参考实现一致：从工作目录向上查找 .env，
# 已存在的真实环境变量优先（override=False）。

# ---------------------------------------------------------------------------
# PostgreSQL / TimescaleDB (P0)
# 本机 compose 栈将容器内 5432 映射到宿主 55432（本项目保留端口）。
# 宿主侧 CLI 直连 compose 里的库时用 TMS_PG_PORT=55432。
# ---------------------------------------------------------------------------
TMS_PG_HOST=127.0.0.1
TMS_PG_PORT=55432
TMS_PG_USER=tms
TMS_PG_PASSWORD=tms
TMS_PG_DATABASE=tms
TMS_PG_SSLMODE=disable
# pgx 连接池规模：MAX 必须 >= 1，MIN 取值 [0, MAX]。
TMS_PG_MAX_CONNS=16
TMS_PG_MIN_CONNS=2

# ---------------------------------------------------------------------------
# Redis (P0) — live 遥测 / streams。compose 将 6379 映射到宿主 56379。
# ---------------------------------------------------------------------------
TMS_REDIS_ADDR=127.0.0.1:56379
TMS_REDIS_DB=0
TMS_REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# 运行时 / 日志
# TMS_LOG_LEVEL: debug / info / warn / error（兼容 Python 风格 DEBUG/INFO/WARNING/ERROR）
# TMS_LOG_FORMAT: auto（终端=console，否则 json）/ console / json
# ---------------------------------------------------------------------------
TMS_LOG_LEVEL=info
TMS_LOG_FORMAT=auto

# `tms api` 监听地址。容器内 :8080，宿主映射 18080（本项目保留端口）。
TMS_API_ADDR=:8080

# Bearer 令牌：所有 /api/* 路由必须携带 `Authorization: Bearer <token>`
# （/healthz、/version 公开）。未设置时 `tms api` 拒绝启动 —— 无鉴权 API 视为配置错误。
# 请填入强随机串（例如 `openssl rand -hex 32`）；UI 以此为 Bearer 令牌调用。
TMS_API_TOKEN=

# 浏览器跨域来源白名单（逗号分隔，留空表示禁止任何跨域）。默认放行本项目 UI 端口 13000。
TMS_API_CORS_ORIGINS=http://localhost:13000,http://127.0.0.1:13000

# ---------------------------------------------------------------------------
# `tms worker` — 后台任务执行器（P1，tms.jobs 持久化队列）
# TMS_WORKER_CONCURRENCY: 并发执行器数量（>= 1）。
# TMS_WORKER_HEALTH_ADDR: /healthz 存活探针监听地址（仅 loopback；
#   容器 healthcheck 通过 `tms worker --health` 在同一网络命名空间内探测）。
# ---------------------------------------------------------------------------
TMS_WORKER_CONCURRENCY=4
TMS_WORKER_HEALTH_ADDR=127.0.0.1:8081

# ---------------------------------------------------------------------------
# `tms scheduler` — 每日增量同步调度器（NYSE 交易日历感知）
# 每个交易日在收盘后的指定时间，向持久化队列 tms.jobs 入队当日流水线：
#   data.refresh source=api（Sharadar 增量 catchup）→ eod.refresh（信号预计算）。
# 通过 tms.scheduler_runs 账本实现幂等 + 单领导（每个交易日恰好一次，
# 即使重启 / 多实例也不会重复入队）；周末与节假日自动跳过。
# TMS_SCHEDULER_DAILY_AT: 触发时刻 HH:MM（24 小时制），在 TMS_SCHEDULER_TZ 时区解释。
#   默认 18:30（约美东收盘后 2.5 小时，Sharadar 已发布当日 EOD）。
# TMS_SCHEDULER_TZ: 解释 DAILY_AT 的 IANA 时区，默认 America/New_York（随夏令时跟踪收盘）。
# TMS_SCHEDULER_CATCHUP: 启动补偿。若在交易日启动且触发时刻已过、当日尚未入队，
#   则补入队一次（重启不漏当日）。默认 true。
# TMS_SCHEDULER_HEALTH_ADDR: /healthz 存活探针地址（容器内通过
#   `tms scheduler --health` 探测，宿主端口 18091）。
# 注意：调度器只负责“入队”，真正的 Nasdaq 同步由 worker 执行（持有 API key），
#   因此调度器无需 NASDAQ_DATA_LINK_API_KEY。
# ---------------------------------------------------------------------------
TMS_SCHEDULER_DAILY_AT=18:30
TMS_SCHEDULER_TZ=America/New_York
TMS_SCHEDULER_CATCHUP=true
TMS_SCHEDULER_HEALTH_ADDR=127.0.0.1:8091

# ---------------------------------------------------------------------------
# Nasdaq Data Link (Sharadar) — 历史 EOD 行情与基本面数据导入
# 注册: https://data.nasdaq.com/account/profile
# 无默认值：`tms import --source api` 运行时通过 Require 校验，缺失即报
# MissingConfig 错误（fail loud and fast）。
# ---------------------------------------------------------------------------
NASDAQ_DATA_LINK_API_KEY=your_key_here

# ---------------------------------------------------------------------------
# Sharadar 本地缓存目录（Parquet，与 Python 参考实现 cache/sharadar 布局兼容）。
# 留空 = 使用仓库根下默认 ./cache/sharadar。
# ---------------------------------------------------------------------------
TMS_SHARADAR_CACHE_DIR=

# ---------------------------------------------------------------------------
# 策略参数解析（centralized-params 方案，与 Python 参考实现一致）。
# 留空 = 使用内置 baseline 参数；设为 runs/active_params 等目录则按
# per-strategy 回退规则加载调优参数。
# ---------------------------------------------------------------------------
TMS_STRATEGY_PARAMS_DIR=

# ---------------------------------------------------------------------------
# 回测产物目录（legacy runs/{ts}/*.json，与 Python 参考实现 TMS_RUNS_DIR 一致）。
# 数据库（research.*）是回测结果的 source of truth；该目录用于 parity 对比
# 与 UI 向后兼容。留空 = 默认 ./runs。
# ---------------------------------------------------------------------------
TMS_RUNS_DIR=

# ---------------------------------------------------------------------------
# 实盘节点 / moomoo OpenD（P5，signal 模式；paper/live 推迟到 P6）。
# TMS_MOOMOO_ADDR 是真实/Mock 的切换开关（locked decision 2）：
#   - 真实本地 OpenD：127.0.0.1:11111（容器内用 host.docker.internal:11111）
#   - 门禁/CI：指向仓内协议级 Mock OpenD 的监听地址
# TMS_MOOMOO_MAX_SUB 为每连接订阅上限（FutuOpenD 文档化的 100 配额）。
# TMS_LIVE_TRADER_ID 是 Redis 命名空间 + sessions.trader_id；API 的实盘流
# 桥接（trader-{id}:stream:*）默认订阅该 trader。
# moomoo 凭据（如有）从 secrets/moomoo.env 读取，绝不写入镜像/日志。
# ---------------------------------------------------------------------------
TMS_MOOMOO_ADDR=127.0.0.1:11111
TMS_MOOMOO_MAX_SUB=100
TMS_LIVE_TRADER_ID=SIGNAL-001
